def test_ciphertensor_transpose(mpc, rows, cols):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((rows, cols))
    
    if mpc.pid > 0:
        encrypted_values_row_wise = Ciphertensor[ckks.Ciphertext].enc(mpc, values)
        encrypted_values_diag_wise = Ciphertensor[ckks.Ciphertext].enc(mpc, values, encoding=ENC_DIAG)

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values_row_wise.T.reveal(mpc, dtype=float).tolist(),
            expected=values.transpose())
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor lazy transpose matrix of shape ({rows}, {cols})", stats.min_precision.l2 > 10, True)

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values_diag_wise.T.reveal(mpc, dtype=float).tolist(),
            expected=values.transpose())
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor lazy diagonal transpose matrix of shape ({rows}, {cols})", stats.min_precision.l2 > 10, True)

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values_row_wise.actual_transpose(mpc).reveal(mpc, dtype=float).tolist(),
            expected=values.transpose())
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor actual transpose matrix of shape ({rows}, {cols})", stats.min_precision.l2 > 10, True)

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values_diag_wise.actual_transpose(mpc).reveal(mpc, dtype=float).tolist(),
            expected=values.transpose())
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor actual diagonal transpose matrix of shape ({rows}, {cols})", stats.min_precision.l2 > 10, True)

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values_diag_wise.actual_transpose(mpc).actual_transpose(mpc).reveal(mpc, dtype=float).tolist(),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor actual diagonal transpose reflection matrix of shape ({rows}, {cols})", stats.min_precision.l2 > 10, True)


@sequre
def test_ciphertensor_lazy_bootstrapping(mpc, rows, cols):
    @sequre
    def _test_bootstrapping_case(mpc, values, msg):
        bootstrap_count = mpc.stats.secure_bootstrap_count
        if mpc.pid > 0:
            encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)
            initial_level = encrypted_values.level()
            m, n = values.shape
            encrypted_ones = Ciphertensor[ckks.Ciphertext].enc(mpc, ones((m, n)))

            for _ in range(initial_level - mpc.mhe.bootstrap_min_level + 1):
                encrypted_values *= encrypted_ones

            stats = precision_stats(
            mpc=mpc,
                result=encrypted_values.reveal(mpc, dtype=float).tolist(),
                expected=values)
            
            local_cipher_size = len(encrypted_values._data)
            council_cipher_sizes = mpc.comms.collect(local_cipher_size)

            if not council_cipher_sizes.same() or not mpc.comms.collect(encrypted_values._data).same():
                expected_stats = council_cipher_sizes.sum()
            else:
                expected_stats = local_cipher_size
            
            bootstrap_count = mpc.stats.secure_bootstrap_count - bootstrap_count
            
            assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor lazy bootstrapping ({msg}) for shape {values.shape}: correctness", stats.min_precision.l2 > 7, True)
            assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor lazy bootstrapping ({msg}) for shape {values.shape}: level", encrypted_values.level(), initial_level)
            assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor lazy bootstrapping ({msg}) for shape {values.shape}: stats", bootstrap_count, expected_stats)
    
    # Case 1: ciphertensors have same size at different parties
    values = random_floats((rows, cols))
    _test_bootstrapping_case(mpc, values, msg="same-size ciphers")

    # Case 2: ciphertensors misaligned at different parties
    values = random_floats((rows * mpc.pid, cols))
    _test_bootstrapping_case(mpc, values, msg="misaligned ciphers")

    # Edge case: fishing for potentially unnecessary bootstraps
    bootstrap_count = mpc.stats.secure_bootstrap_count
    values = random_floats((4, 4))
    fat_values = random_floats((4, 32))

    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)

        power_matrix = encrypted_values.copy()
        for _ in range(2):
            power_matrix @= encrypted_values.T

        bootstrap_count = mpc.stats.secure_bootstrap_count - bootstrap_count
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor lazy bootstrapping (fishing) for shape ({rows}, {cols}): stats", bootstrap_count, 16 * (mpc.comms.number_of_parties - 1))
        bootstrap_count = mpc.stats.secure_bootstrap_count
        power_matrix = power_matrix.T @ Ciphertensor[ckks.Ciphertext].enc(mpc, fat_values)
        bootstrap_count = mpc.stats.secure_bootstrap_count - bootstrap_count
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor lazy bootstrapping (fishing) for shape ({rows}, {cols}): stats", bootstrap_count, 8 * (mpc.comms.number_of_parties - 1))
    

@sequre
def test_ciphertensor_lazy_rescaling(mpc, rows, cols):
    initial_rescale_count = mpc.stats.secure_rescale_count
    with mpc.randomness.seed_switch(-1):
        values = random_floats((rows, cols))
    
    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)
        encrypted_ones = Ciphertensor[ckks.Ciphertext].enc(mpc, ones((rows, cols)))

        for i in range(10):
            encrypted_values *= encrypted_ones
            rescale_count = mpc.stats.secure_rescale_count - initial_rescale_count
            assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor lazy rescaling for shape ({rows}, {cols}) after {i + 1} muls: stats", rescale_count, i * len(encrypted_values._data))

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values.reveal(mpc, dtype=float).tolist(),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor lazy rescaling for shape ({rows}, {cols}): correctness", stats.min_precision.l2 > 7, True)


def test_ciphertensor_binary_operation(mpc, op, rows, cols, msg):
    with mpc.randomness.seed_switch(-1):
        values_1 = random_floats((rows, cols))
        values_2 = random_floats((rows, cols))
    
    if mpc.pid > 0:
        encrypted_values_1 = Ciphertensor[ckks.Ciphertext].enc(mpc, values_1)
        encrypted_values_2 = Ciphertensor[ckks.Ciphertext].enc(mpc, values_2)

        result = op(mpc, encrypted_values_1, encrypted_values_2)
        stats = precision_stats(
            mpc=mpc,
            result=result.reveal(mpc, dtype=float).tolist(),
            expected=op(mpc, values_1, values_2))
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor {msg} for shape ({rows}, {cols})", stats.min_precision.l2 > 9, True)


def test_ciphertensor_pow(mpc, rows, cols):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((rows, cols))
        power = 3

    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)

        result = secure_operator.pow(mpc, encrypted_values, power)
        stats = precision_stats(
            mpc=mpc,
            result=result.reveal(mpc, dtype=float).tolist(),
            expected=values ** power)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor pow for shape ({rows}, {cols})", stats.min_precision.l2 > 6, True)


def test_ciphertensor_reduce_add(mpc, cols):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((cols,))
    
    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)
        reduced_encrypted_values = encrypted_values.reduce_add(mpc)
        reduced_value = values.sum()

        stats = precision_stats(
            mpc=mpc,
            result=reduced_encrypted_values.reveal(mpc, dtype=float).flatten().tolist(),
            expected=[reduced_value for _ in range(cols)])
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor addition reduction for vector of size {cols}", stats.min_precision.l2 > 10, True)


def test_ciphertensor_dot_product(mpc, rows, cols):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((rows, cols))
    
    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)

        dot_product_axis_0 = encrypted_values.dot(mpc, axis=0)
        stats = precision_stats(
            mpc=mpc,
            result=dot_product_axis_0.reveal(mpc, dtype=float).flatten().tolist(),
            expected=(values * values).sum())
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor dot product over axis 0 for shape ({rows}, {cols})", stats.min_precision.l2 > 7, True)

        dot_product_axis_1 = encrypted_values.dot(mpc, axis=1)
        stats = precision_stats(
            mpc=mpc,
            result=dot_product_axis_1.reveal(mpc, dtype=float).flatten().tolist(),
            expected=(values * values).transpose().sum())
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor dot product over axis 1 for shape ({rows}, {cols})", stats.min_precision.l2 > 7, True)


@sequre
def test_ciphertensor_matrix_multiplication(mpc, rows: int, cols: int, only_general: bool):
    with mpc.randomness.seed_switch(-1):
        values_1 = random_floats((rows, cols))
        values_2 = random_floats((rows, cols))
    
    if mpc.pid > 0:
        encrypted_values_1 = Ciphertensor[ckks.Ciphertext].enc(mpc, values_1, encoding=ENC_ROW)
        encrypted_values_2 = Ciphertensor[ckks.Ciphertext].enc(mpc, values_2, encoding=ENC_ROW)

        if not only_general:
            result_v1 = encrypted_values_1._matmul_v1(mpc, encrypted_values_2.T, debug=1)        
            stats = precision_stats(
            mpc=mpc,
                result=result_v1.reveal(mpc, dtype=float).tolist(),
                expected=values_1 @ values_2.transpose())
            assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor _matmul_v1 for shape ({rows}, {cols})", stats.min_precision.l2 > 5, True)

            encrypted_values_2_t = Ciphertensor[ckks.Ciphertext].enc(mpc, values_2.transpose(), encoding=ENC_ROW)
            result_v2 = encrypted_values_1._matmul_v2(mpc, encrypted_values_2_t, debug=1)
            stats = precision_stats(
            mpc=mpc,
                result=result_v2.reveal(mpc, dtype=float).tolist(),
                expected=values_1 @ values_2.transpose())
            assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor _matmul_v2 for shape ({rows}, {cols})", stats.min_precision.l2 > 5, True)
            
            if rows.popcnt() == 1 and cols.popcnt() == 1:  # Temp constrain. Until arbitrary dimensions are enabled for _matmul_v3.
                encrypted_values_1_d_contig = Ciphertensor[ckks.Ciphertext].enc(mpc, values_1, encoding=ENC_DIAG)
                encrypted_values_2_d_contig = Ciphertensor[ckks.Ciphertext].enc(mpc, values_2.transpose(), encoding=ENC_DIAG)
                
                result_v3_01 = encrypted_values_1._matmul_v3(mpc, encrypted_values_2_d_contig, debug=1)
                stats = precision_stats(
                    mpc=mpc,
                    result=result_v3_01.reveal(mpc, dtype=float).tolist(),
                    expected=values_1 @ values_2.transpose())
                assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor _matmul_v3 (row-wise x diag-wise) for shape ({rows}, {cols})", stats.min_precision.l2 > 4, True)

                result_v3_11 = encrypted_values_1_d_contig._matmul_v3(mpc, encrypted_values_2_d_contig, debug=1)
                stats = precision_stats(
                    mpc=mpc,
                    result=result_v3_11.reveal(mpc, dtype=float).tolist(),
                    expected=values_1 @ values_2.transpose())
                assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor _matmul_v3 (diag-wise x diag-wise case first operand wide) for shape ({rows}, {cols})", stats.min_precision.l2 > 4, True)

                encrypted_values_1_d_contig = Ciphertensor[ckks.Ciphertext].enc(mpc, values_1.transpose(), encoding=ENC_DIAG)
                encrypted_values_2_d_contig = Ciphertensor[ckks.Ciphertext].enc(mpc, values_2, encoding=ENC_DIAG)
                result_v3_11 = encrypted_values_1_d_contig._matmul_v3(mpc, encrypted_values_2_d_contig, debug=1)

                stats = precision_stats(
                    mpc=mpc,
                    result=result_v3_11.reveal(mpc, dtype=float).tolist(),
                    expected=values_1.transpose() @ values_2)
                assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor _matmul_v3 (diag-wise x diag-wise case first operand tall) for shape ({rows}, {cols})", stats.min_precision.l2 > 4, True)

            result_t = encrypted_values_1.T @ values_2

            stats = precision_stats(
            mpc=mpc,
                result=result_t.reveal(mpc, dtype=float).tolist(),
                expected=values_1.transpose() @ values_2)
            assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor matmul transposed general for shape ({rows}, {cols})", stats.min_precision.l2 > 4, True)
        
        if rows.popcnt() == 1 and cols.popcnt() == 1:  # Temp constraint. Until arbitrary dimensions are enabled for _matmul_v3.
            result_general = encrypted_values_1 @ values_2.transpose()

            stats = precision_stats(
            mpc=mpc,
                result=result_general.reveal(mpc, dtype=float).tolist(),
                expected=values_1 @ values_2.transpose())
            assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor matmul general for shape ({rows}, {cols})", stats.min_precision.l2 > 4, True)


@sequre
def test_ciphertensor_matrix_multiplication_for_shapes(mpc, rows_1: int, cols_1: int, rows_2: int, cols_2: int):
    with mpc.randomness.seed_switch(-1):
        values_1 = random_floats((rows_1, cols_1), scale=1)
        values_2 = random_floats((rows_2, cols_2), scale=1)
    
    if mpc.pid > 0:
        encrypted_values_1_d_contig = Ciphertensor[ckks.Ciphertext].enc(mpc, values_1, encoding=ENC_DIAG)
        encrypted_values_2_d_contig = Ciphertensor[ckks.Ciphertext].enc(mpc, values_2, encoding=ENC_DIAG)
        
        result_v3_11 = encrypted_values_1_d_contig._matmul_v3(mpc, encrypted_values_2_d_contig, debug=1)
        revealed_result_v3_11 = result_v3_11.reveal(mpc, dtype=float).tolist()
        stats = precision_stats(
            mpc=mpc,
            result=revealed_result_v3_11,
            expected=values_1 @ values_2)
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor _matmul_v3 (diag-wise x diag-wise) for shapes ({rows_1}, {cols_1}) x ({rows_2}, {cols_2})", stats.min_precision.l2 > 2, True)


@sequre
def test_ciphertensor_reversed_matrix_multiplication(mpc, rows, cols):
    with mpc.randomness.seed_switch(-1):
        values_1 = random_floats((rows, cols))
        values_2 = random_floats((rows, cols))
    
    if mpc.pid > 0:
        encrypted_values_2_t = Ciphertensor[ckks.Ciphertext].enc(mpc, values_2.transpose())

        result = array(values_1) @ encrypted_values_2_t
        stats = precision_stats(
            mpc=mpc,
            result=result.reveal(mpc, dtype=float).tolist(),
            expected=values_1 @ values_2.transpose())
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor reversed matmul for shape ({rows}, {cols})", stats.min_precision.l2 > 7, True)


def test_ciphertensor_vector_operations(mpc, rows, cols):
    test_ciphertensor_getitem(mpc, rows, cols)
    test_ciphertensor_setitem(mpc, rows, cols)
    test_ciphertensor_append(mpc, rows, cols)
    test_ciphertensor_pop(mpc, rows, cols)
    test_ciphertensor_extend(mpc, rows, cols)
    test_ciphertensor_rotation(mpc, cols)
    test_ciphertensor_shift(mpc, cols)
    test_ciphertensor_concat(mpc, rows, cols)
    test_ciphertensor_resize(mpc, cols, cols)
    test_ciphertensor_resize(mpc, cols, cols // 2)
    test_ciphertensor_resize(mpc, cols, cols * 2)
    test_ciphertensor_resize(mpc, mpc.mhe.crypto_params.params.slots() + cols, cols)
    test_ciphertensor_patch_copy(mpc, cols, cols * 2)
    test_ciphertensor_patch_copy(mpc, cols // 2, cols * 2)
    test_ciphertensor_patch_copy_matrix(mpc, rows, cols, cols * 2)
    test_ciphertensor_patch_copy_matrix(mpc, rows, cols // 2, cols * 2)


def test_ciphertensor_binary_operations(mpc, rows, cols):
    test_ciphertensor_binary_operation(mpc, secure_operator.add, rows, cols, f"addition ({rows} x {cols})")
    test_ciphertensor_binary_operation(mpc, secure_operator.sub, rows, cols, f"subtraction ({rows} x {cols})")
    test_ciphertensor_binary_operation(mpc, secure_operator.mul, rows, cols, f"multiplication ({rows} x {cols})")
    test_ciphertensor_pow(mpc, rows, cols)


def test_ciphertensor_arithmetics(mpc):
    test_ciphertensor_transpose(mpc, 4, 32)
    test_ciphertensor_transpose(mpc, 7, 7)
    test_ciphertensor_binary_operations(mpc, 4, mpc.mhe.crypto_params.params.slots() * 3)
    test_ciphertensor_binary_operations(mpc, 7, 7)
    test_ciphertensor_reduce_add(mpc, 32)
    test_ciphertensor_reduce_add(mpc, 7)
    test_ciphertensor_reduce_add(mpc, mpc.mhe.crypto_params.params.slots() // 2)
    test_ciphertensor_reduce_add(mpc, mpc.mhe.crypto_params.params.slots())
    test_ciphertensor_reduce_add(mpc, mpc.mhe.crypto_params.params.slots() + 32)
    test_ciphertensor_dot_product(mpc, 4, 32)
    test_ciphertensor_dot_product(mpc, 7, 7)
    test_ciphertensor_matrix_multiplication(mpc, 4, 32, False)
    test_ciphertensor_matrix_multiplication(mpc, 8, 4, False)
    test_ciphertensor_matrix_multiplication(mpc, 4, mpc.mhe.crypto_params.params.slots(), True)
    test_ciphertensor_matrix_multiplication(mpc, 7, 7, False)
    test_ciphertensor_matrix_multiplication_for_shapes(mpc, 16, 8, 8, 4)
    test_ciphertensor_matrix_multiplication_for_shapes(mpc, 128, mpc.mhe.crypto_params.params.slots(), mpc.mhe.crypto_params.params.slots(), 4)
    test_ciphertensor_reversed_matrix_multiplication(mpc, 4, 8)
    test_ciphertensor_reversed_matrix_multiplication(mpc, 8, 4)
    test_ciphertensor_reversed_matrix_multiplication(mpc, 7, 7)


def test_ciphertensor(mpc):
    print(f'CP{mpc.pid}:\tTesting Sequre MHE Ciphertensor ... \n')
    test_ciphertensor_send_receive(mpc)
    test_ciphertensor_encrypt_reveal(mpc, mpc.mhe.crypto_params.params.slots() * 3)
    test_ciphertensor_encrypt_reveal(mpc, 32)
    test_ciphertensor_encrypt_reveal(mpc, mpc.mhe.crypto_params.params.slots() + 32)
    test_ciphertensor_encrypt_reveal(mpc, 7)
    test_ciphertensor_vector_operations(mpc, 4, 32)
    test_ciphertensor_vector_operations(mpc, 4, mpc.mhe.crypto_params.params.slots())
    test_ciphertensor_vector_operations(mpc, 4, mpc.mhe.crypto_params.params.slots() * 3 // 2)
    test_ciphertensor_vector_operations(mpc, 4, mpc.mhe.crypto_params.params.slots() * 3)
    test_ciphertensor_vector_operations(mpc, 7, 21)
    test_ciphertensor_vector_operations(mpc, 7, mpc.mhe.crypto_params.params.slots() + 1)
    test_ciphertensor_lazy_bootstrapping(mpc, 4 ,32)
    test_ciphertensor_lazy_bootstrapping(mpc, 7 ,7)
    test_ciphertensor_lazy_rescaling(mpc, 4 ,32)
    test_ciphertensor_lazy_rescaling(mpc, 7 ,7)
    test_ciphertensor_arithmetics(mpc)
    print(f'CP{mpc.pid}:\tSequre MHE Ciphertensor tests passed.\n')
