def test_ciphertensor_extend(mpc, rows, cols):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((rows, cols))
    
    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)
        encrypted_zeros = Ciphertensor.zeros(mpc, [rows, cols])
        encrypted_values = encrypted_values.concatenate(mpc, encrypted_zeros)
        values.extend(zeros((rows, cols), TP=float))

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values.reveal(mpc, dtype=float).tolist(),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor matrix extend ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        
    with mpc.randomness.seed_switch(-1):
        values_vec = random_floats((cols,))
        
    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values_vec)
        encrypted_values = encrypted_values.concatenate(mpc, Ciphertensor.zeros(mpc, [cols]))
        values_vec.extend(zeros((cols,), TP=float))

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values.reveal(mpc, dtype=float).flatten().tolist(),
            expected=values_vec)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor vector extend (size: {cols})", stats.min_precision.l2 > 10, True)


def test_ciphertensor_rotation(mpc, cols):
    rotation_step = 131
    with mpc.randomness.seed_switch(-1):
        values = random_floats((cols,))
    
    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)
        rotated_encrypted_values = encrypted_values.rotate(mpc, rotation_step)

        stats = precision_stats(
            mpc=mpc,
            result=rotated_encrypted_values.reveal(mpc, dtype=float).flatten().tolist(),
            expected=values.rotate(rotation_step))
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor rotation (size: {cols})", stats.min_precision.l2 > 10, True)


def test_ciphertensor_shift(mpc, cols):
    slots = mpc.mhe.crypto_params.params.slots()
    rotation_step = 3
    with mpc.randomness.seed_switch(-1):
        values = random_floats((cols,))
    
    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)
        rotated_encrypted_values_cohort = encrypted_values.shift(mpc, rotation_step)
        shifted_values = values.shift_like_cipher(rotation_step, slots, cols)
        result = rotated_encrypted_values_cohort.reveal(mpc, dtype=float).flatten().tolist()

        stats = precision_stats(
            mpc=mpc,
            result=result,
            expected=shifted_values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor shift of vector length {cols}", stats.min_precision.l2 > 10, True)


