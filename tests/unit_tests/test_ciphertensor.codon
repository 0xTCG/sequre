from numpy import array, ones

import secure_operator
import sequre.lattiseq.ckks as ckks

from sequre import sequre
from sequre.types.ciphertensor import Ciphertensor
from sequre.utils.stats import precision_stats
from sequre.utils.testing import assert_eq
from sequre.utils.utils import zeros, random_floats
from sequre.constants import ENC_DIAG, ENC_ROW


def test_ciphertensor_send_receive(mpc):
    if mpc.pid == 1:
        with mpc.randomness.seed_switch(2):
            values = random_floats((mpc.mhe.crypto_params.params.slots(),))

        ct = Ciphertensor[ckks.Ciphertext].enc(mpc, values)
        mpc.comms.send_as_jar(ct, 2)
        received_ct = mpc.comms.receive_as_jar(2, Ciphertensor[ckks.Ciphertext])
    elif mpc.pid == 2:
        with mpc.randomness.seed_switch(1):
            values = random_floats((mpc.mhe.crypto_params.params.slots(),))
        
        ct = Ciphertensor[ckks.Ciphertext].enc(mpc, values)
        received_ct = mpc.comms.receive_as_jar(1, Ciphertensor[ckks.Ciphertext])
        mpc.comms.send_as_jar(ct, 1)

    if 0 < mpc.pid < 3:
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor send/receive", ct, received_ct)


def test_ciphertensor_encrypt_reveal(mpc, size):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((size,))
    
    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values.reveal(mpc, dtype=float).flatten().tolist(),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor encrypt/reveal of size {size}", stats.min_precision.l2 > 10, True)


def test_ciphertensor_getitem(mpc, rows, cols):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((rows, cols))
    
    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)
        encrypted_row = encrypted_values._getitem(mpc, 0)

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_row.reveal(mpc, dtype=float).flatten().tolist(),
            expected=values[0])
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim getitem ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        encrypted_elem = encrypted_row._getitem(mpc, 0)

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_elem.reveal(mpc, dtype=float).flatten().tolist()[0],
            expected=values[0][0])
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 1-dim getitem ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        rs = slice(start=0, stop=2, step=1)
        cs = slice(start=0, stop=2, step=1)
        
        encrypted_slice = encrypted_values._getitem(mpc, rs)

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_slice.reveal(mpc, dtype=float).tolist(),
            expected=values[rs])
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim get slice ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        encrypted_slice = encrypted_values._getitem(mpc, (rs, cs))

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_slice.reveal(mpc, dtype=float).tolist(),
            expected=values[rs, cs])
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim get slice-slice tuple ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        encrypted_slice = encrypted_values._getitem(mpc, (rs, 2))

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_slice.reveal(mpc, dtype=float).tolist(),
            expected=values[rs, 2:3])
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim get slice-int tuple ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        encrypted_slice = encrypted_values._getitem(mpc, (2, cs))

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_slice.reveal(mpc, dtype=float).flatten().tolist(),
            expected=values[2, cs])
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim get int-slice tuple ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        encrypted_slice = encrypted_values._getitem(mpc, (2, 2))

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_slice.reveal(mpc, dtype=float).flatten().tolist(),
            expected=values[2, 2:3])
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim get int-int tuple ({rows} x {cols})", stats.min_precision.l2 > 10, True)


def test_ciphertensor_setitem(mpc, rows, cols):
    with mpc.randomness.seed_switch(-1):
        _values = random_floats((rows, cols))
    
    if mpc.pid > 0:
        _encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, _values)
        
        encrypted_values = _encrypted_values.copy()
        values = _values.copy()
        encrypted_values._setitem(mpc, 0, encrypted_values._getitem(mpc, 1))
        values[0] = values[1]

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values.reveal(mpc, dtype=float).tolist(),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim setitem ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        encrypted_row = encrypted_values._getitem(mpc, 0)
        encrypted_row._setitem(mpc, 0, encrypted_row._getitem(mpc, 1))
        values[0][0] = values[0][1]

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_row.reveal(mpc, dtype=float).flatten().tolist(),
            expected=values[0])
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 1-dim setitem ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        rs_set = slice(start=0, stop=2, step=1)
        cs_set = slice(start=0, stop=2, step=1)
        rs_get = slice(start=1, stop=3, step=1)
        cs_get = slice(start=1, stop=3, step=1)
        
        encrypted_values = _encrypted_values.copy()
        values = _values.copy()
        encrypted_values._setitem(mpc, rs_set, encrypted_values._getitem(mpc, rs_get))
        values[rs_set] = values[rs_get]

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values.reveal(mpc, dtype=float).tolist(),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim set slice ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        encrypted_values = _encrypted_values.copy()
        values = _values.copy()
        set_slice_tuple = (rs_set, cs_set)
        get_slice_tuple = (rs_get, cs_get)
        encrypted_values._setitem(mpc, set_slice_tuple, encrypted_values._getitem(mpc, get_slice_tuple))
        values[set_slice_tuple] = values[get_slice_tuple]

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values.reveal(mpc, dtype=float).tolist(),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim set slice-slice tuple ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        encrypted_values = _encrypted_values.copy()
        values = _values.copy()
        set_slice_tuple = (rs_set, 1)
        get_slice_tuple = (rs_get, 2)
        encrypted_values._setitem(mpc, set_slice_tuple, encrypted_values._getitem(mpc, get_slice_tuple))
        values[set_slice_tuple] = values[get_slice_tuple]

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values.reveal(mpc, dtype=float).tolist(),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim set slice-int tuple ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        encrypted_values = _encrypted_values.copy()
        values = _values.copy()
        set_slice_tuple = (2, cs_set)
        get_slice_tuple = (3, cs_get)
        encrypted_values._setitem(mpc, set_slice_tuple, encrypted_values._getitem(mpc, get_slice_tuple))
        values[set_slice_tuple] = values[get_slice_tuple]

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values.reveal(mpc, dtype=float).tolist(),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim set int-slice tuple ({rows} x {cols})", stats.min_precision.l2 > 10, True)

        encrypted_values = _encrypted_values.copy()
        values = _values.copy()
        set_slice_tuple = (2, 1)
        get_slice_tuple = (3, 2)
        encrypted_values._setitem(mpc, set_slice_tuple, encrypted_values._getitem(mpc, get_slice_tuple))
        values[set_slice_tuple] = values[get_slice_tuple]

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values.reveal(mpc, dtype=float).tolist(),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor 2-dim set int-int tuple ({rows} x {cols})", stats.min_precision.l2 > 10, True)

def test_ciphertensor_append(mpc, rows, cols):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((rows, cols))
    
    if mpc.pid > 0:
        encrypted_values = Ciphertensor[ckks.Ciphertext].enc(mpc, values)
        encrypted_values.append(Ciphertensor.zeros(mpc, [cols]))
        values.append(zeros((cols,), TP=float))

        stats = precision_stats(
            mpc=mpc,
            result=encrypted_values.reveal(mpc, dtype=float).tolist(),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tSequre MHE ciphertensor append ({rows} x {cols})", stats.min_precision.l2 > 10, True)


