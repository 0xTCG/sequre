import prg

from copy import copy

import sequre.lattiseq.ckks as ckks
import sequre.lattiseq.ring as ring
import sequre.lattiseq.ringqp as ringqp

from sequre.utils.stats import precision_stats
from sequre.utils.testing import assert_eq
from sequre.utils.utils import random_floats
from sequre.constants import MPC_FIELD_SIZE, MPC_RING_SIZE
from sequre.types.utils import fp_to_double, double_to_fp


def test_send_receive_poly(mpc):
    q = ring.new_poly(10, 10)
    p = ring.new_poly(10, 10)
    qp = ringqp.Poly(q=q, p=p)

    received_q = copy(q)
    received_qp = copy(qp)

    if mpc.pid == 1:
        mpc.randomness.switch_seed(2)
        q.randomize(upper_bound=u64(100))
        p.randomize(upper_bound=u64(100))
        mpc.randomness.restore_seed(2)
        
        mpc.comms.send_as_jar(q, 2)
        mpc.comms.send_as_jar(qp, 2)
        received_q = mpc.comms.receive_as_jar(2, ring.Poly)
        received_qp = mpc.comms.receive_as_jar(2, ringqp.Poly)
    elif mpc.pid == 2:
        mpc.randomness.switch_seed(1)
        q.randomize(upper_bound=u64(100))
        p.randomize(upper_bound=u64(100))
        mpc.randomness.restore_seed(1)
        
        received_q = mpc.comms.receive_as_jar(1, ring.Poly)
        received_qp = mpc.comms.receive_as_jar(1, ringqp.Poly)
        mpc.comms.send_as_jar(q, 1)
        mpc.comms.send_as_jar(qp, 1)

    assert_eq(f"CP{mpc.pid}:\tMHE send/receive poly", received_q, q)
    assert_eq(f"CP{mpc.pid}:\tMHE send/receive QP poly", received_qp, qp)


def test_send_receive_ciphertext(mpc):
    gen = mpc.mhe.crypto_params.encryptor.prng.gen
    old_state = gen.get_state()

    ct = ckks.Ciphertext()
    received_ct = ckks.Ciphertext()

    if mpc.pid == 1:
        mpc.randomness.switch_seed(2)
        values = random_floats((mpc.mhe.crypto_params.params.slots(),))
        mpc.mhe.crypto_params.fixate_encryptor_prng(mpc.randomness.get_state())
        ct = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)[0]
        mpc.randomness.restore_seed(2)
        mpc.mhe.crypto_params.fixate_encryptor_prng(old_state)
        
        mpc.comms.send_as_jar(ct, 2)
        received_ct = mpc.comms.receive_as_jar(2, ckks.Ciphertext)
    elif mpc.pid == 2:
        mpc.randomness.switch_seed(1)
        values = random_floats((mpc.mhe.crypto_params.params.slots(),))
        mpc.mhe.crypto_params.fixate_encryptor_prng(mpc.randomness.get_state())
        ct = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)[0]
        mpc.randomness.restore_seed(1)
        mpc.mhe.crypto_params.fixate_encryptor_prng(old_state)
        
        received_ct = mpc.comms.receive_as_jar(1, ckks.Ciphertext)
        mpc.comms.send_as_jar(ct, 1)
    
    assert_eq(f"CP{mpc.pid}:\tMHE send/receive ciphertext", ct, received_ct)


def test_decryption(mpc):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),))
    
    if mpc.pid > 0:
        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(
                    mpc.mhe.enc_vector(values, T=ckks.Ciphertext)),
                dtype=float),
            expected=values)
    
        assert_eq(f"CP{mpc.pid}:\tMHE collective decryption", stats.min_precision.l2 > 11, True)


def test_const_addition(mpc):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),))
        constant = prg.random() * 7

    if mpc.pid > 0:
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)
        result = mpc.mhe.add_const(ciphervector, constant)

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(result),
                dtype=float),
            expected=values + constant)
        
        assert_eq(f"CP{mpc.pid}:\tMHE const addition", stats.min_precision.l2 > 10, True)


def test_const_subtraction(mpc):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),))
        constant = prg.random() * 7

    if mpc.pid > 0:
        ciphervector_1 = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)
        result = mpc.mhe.sub_const(ciphervector_1, constant)

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(result),
                dtype=float),
            expected=values - constant)
        
        assert_eq(f"CP{mpc.pid}:\tMHE const subtraction", stats.min_precision.l2 > 10, True)


def test_const_multiplication(mpc):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),))
        constant = prg.random() * 7
    
    if mpc.pid > 0:
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)
        result = mpc.mhe.mul_const(ciphervector, constant)

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(result),
                dtype=float),
            expected=values * constant)
        
        assert_eq(f"CP{mpc.pid}:\tMHE const multiplication level", result[0].level(), ciphervector[0].level())
        assert_eq(f"CP{mpc.pid}:\tMHE const multiplication result", stats.min_precision.l2 >= 10, True)


def test_addition(mpc):
    with mpc.randomness.seed_switch(-1):
        values_1 = random_floats((mpc.mhe.crypto_params.params.slots(),))
        values_2 = random_floats((mpc.mhe.crypto_params.params.slots(),))

    if mpc.pid > 0:
        ciphervector_1 = mpc.mhe.enc_vector(values_1, T=ckks.Ciphertext)
        ciphervector_2 = mpc.mhe.enc_vector(values_2, T=ckks.Ciphertext)
        ciphertext_sum = mpc.mhe.add(ciphervector_1, ciphervector_2)

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(ciphertext_sum),
                dtype=float),
            expected=values_1 + values_2)
        
        assert_eq(f"CP{mpc.pid}:\tMHE addition", stats.min_precision.l2 > 10, True)


def test_subtraction(mpc):
    with mpc.randomness.seed_switch(-1):
        values_1 = random_floats((mpc.mhe.crypto_params.params.slots(),))
        values_2 = random_floats((mpc.mhe.crypto_params.params.slots(),))

    if mpc.pid > 0:
        ciphervector_1 = mpc.mhe.enc_vector(values_1, T=ckks.Ciphertext)
        ciphervector_2 = mpc.mhe.enc_vector(values_2, T=ckks.Ciphertext)
        ciphertext_sum = mpc.mhe.sub(ciphervector_1, ciphervector_2)

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(ciphertext_sum),
                dtype=float),
            expected=values_1 - values_2)
        
        assert_eq(f"CP{mpc.pid}:\tMHE addition", stats.min_precision.l2 > 10, True)


def test_multiplication(mpc):
    with mpc.randomness.seed_switch(-1):
        values_1 = random_floats((mpc.mhe.crypto_params.params.slots(),))
        values_2 = random_floats((mpc.mhe.crypto_params.params.slots(),))
    
    if mpc.pid > 0:
        ciphervector_1 = mpc.mhe.enc_vector(values_1, T=ckks.Ciphertext)
        ciphervector_2 = mpc.mhe.enc_vector(values_2, T=ckks.Ciphertext)
        ciphertext_product = mpc.mhe.mul(ciphervector_1, ciphervector_2)

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(ciphertext_product),
                dtype=float),
            expected=values_1 * values_2)
        
        assert_eq(f"CP{mpc.pid}:\tMHE multiplication level", ciphertext_product[0].level(), ciphervector_1[0].level())
        assert_eq(f"CP{mpc.pid}:\tMHE multiplication result", stats.min_precision.l2 >= 10, True)


def test_rotation(mpc):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),))
        k = prg.randint(1, 10)
        expected_values = values[k:]
        expected_values.extend(values[:k])
    
    if mpc.pid > 0:
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)
        rotated_ciphervector = mpc.mhe.rotate(ciphervector, k)

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(rotated_ciphervector),
                dtype=float),
            expected=expected_values)
        
        assert_eq(f"CP{mpc.pid}:\tMHE rotation by {k} result", stats.min_precision.l2 > 10, True)


def test_arithmetics(mpc):
    test_const_addition(mpc)
    test_const_subtraction(mpc)
    test_const_multiplication(mpc)
    test_addition(mpc)
    test_subtraction(mpc)
    test_multiplication(mpc)
    test_rotation(mpc)


def test_collective_bootstrapping(mpc):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),))
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)

    if mpc.pid > 0:
        initial_level = ciphervector[0].level()

        mpc.mhe.crypto_params.evaluator.drop_level(ciphervector[0], initial_level - mpc.mhe.bootstrap_min_level - 1)
        ciphertext_bootstrapped = mpc.comms.broadcast_from(ciphervector[0], mpc.comms.hub_pid)
        mpc.mhe._collective_bootstrap(ciphertext_bootstrapped, -1)
        ciphertext_bootstrapped = mpc.comms.broadcast_from(ciphertext_bootstrapped, mpc.comms.hub_pid)
        boot_lvl = ciphertext_bootstrapped.level()

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt([ciphertext_bootstrapped], -1),
                dtype=float),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tMHE collective bootstrapping level (Bootstrapped level: {boot_lvl}. Initial level: {initial_level}. Reduced level: {ciphervector[0].level()})", boot_lvl, initial_level)
        assert_eq(f"CP{mpc.pid}:\tMHE collective bootstrapping result", stats.min_precision.l2 > 13, True)


def test_cipher_to_additive_plaintext_conversion(mpc):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),))

    if mpc.pid > 0:
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)

        secret_share = mpc.mhe.cipher_to_additive_plaintext(ciphervector[0], mpc.comms.hub_pid)
        ciphertext = mpc.mhe.additive_plaintext_to_cipher(secret_share, mpc.comms.hub_pid)

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt([ciphertext]),
                dtype=float),
            expected=values)
        
        if mpc.pid == mpc.comms.hub_pid:
            assert_eq(f"CP{mpc.pid}:\tMHE E2S and S2E switching", stats.min_precision.l2 > 13, True)


def test_cipher_to_additive_share_vec_conversion(mpc, mpc_modulus):
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),))

    if mpc.pid > 0:
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)

        secret_share = mpc.mhe.ciphervector_to_additive_share_vector(ciphervector, len(values), mpc_modulus, source_pid=1)
        ciphervector = mpc.mhe.additive_share_vector_to_ciphervector(secret_share, mpc_modulus, True)

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(ciphervector),
                dtype=float),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tMHE additive-share and ciphertext switching on {'ring' if mpc_modulus.popcnt() == 1 else 'field'}", stats.min_precision.l2 > 10, True)


def test_mhe_mpc_conversion_additive_shares_sum_correctly(mpc, mpc_modulus):
    """Test that additive shares from all parties sum to the original value."""
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),), scale=5.0)

    if mpc.pid > 0:
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)
        secret_share = mpc.mhe.ciphervector_to_additive_share_vector(ciphervector, len(values), mpc_modulus, source_pid=1)
        
        # Reveal shares and verify they sum to the original values
        revealed_sum = mpc.comms.reveal(secret_share, mpc_modulus)
        revealed_values = fp_to_double(revealed_sum, mpc_modulus)
        
        stats = precision_stats(
            mpc=mpc,
            result=revealed_values,
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tMHE->MPC additive shares sum correctly", stats.min_precision.l2 > 10, True)


def test_mhe_mpc_conversion_double_roundtrip(mpc, mpc_modulus):
    """Test that double round-trip conversion preserves values."""
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),), scale=3.0)

    if mpc.pid > 0:
        # First round-trip
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)
        secret_share = mpc.mhe.ciphervector_to_additive_share_vector(ciphervector, len(values), mpc_modulus, source_pid=1)
        ciphervector = mpc.mhe.additive_share_vector_to_ciphervector(secret_share, mpc_modulus, True)
        
        # Second round-trip
        secret_share2 = mpc.mhe.ciphervector_to_additive_share_vector(ciphervector, len(values), mpc_modulus, source_pid=1)
        ciphervector2 = mpc.mhe.additive_share_vector_to_ciphervector(secret_share2, mpc_modulus, True)

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(ciphervector2),
                dtype=float),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tMHE<->MPC double roundtrip", stats.min_precision.l2 > 8, True)


def test_mhe_mpc_conversion_negative_values(mpc, mpc_modulus):
    """Test conversion with negative values."""
    slots = mpc.mhe.crypto_params.params.slots()
    with mpc.randomness.seed_switch(-1):
        # Generate values in range [-5, 5]
        values = [prg.random() * 10.0 - 5.0 for _ in range(slots)]

    if mpc.pid > 0:
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)
        secret_share = mpc.mhe.ciphervector_to_additive_share_vector(ciphervector, len(values), mpc_modulus, source_pid=1)
        ciphervector_back = mpc.mhe.additive_share_vector_to_ciphervector(secret_share, mpc_modulus, True)

        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(ciphervector_back),
                dtype=float),
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tMHE<->MPC negative values", stats.min_precision.l2 > 10, True)


def test_mhe_mpc_conversion_partial_slots(mpc, mpc_modulus):
    """Test conversion with partially filled slots."""
    slots = mpc.mhe.crypto_params.params.slots()
    partial_size = slots // 3  # Use only 1/3 of slots
    
    with mpc.randomness.seed_switch(-1):
        values = random_floats((partial_size,), scale=4.0)

    if mpc.pid > 0:
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)
        secret_share = mpc.mhe.ciphervector_to_additive_share_vector(ciphervector, partial_size, mpc_modulus, source_pid=1)
        ciphervector_back = mpc.mhe.additive_share_vector_to_ciphervector(secret_share, mpc_modulus, True)

        result = mpc.mhe.decode(enc=mpc.mhe.decrypt(ciphervector_back), dtype=float)
        stats = precision_stats(
            mpc=mpc,
            result=result[:partial_size],
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tMHE<->MPC partial slots ({partial_size}/{slots})", stats.min_precision.l2 > 10, True)


def test_mhe_mpc_conversion_multiple_ciphertexts(mpc, mpc_modulus):
    """Test conversion with values spanning multiple ciphertexts."""
    slots = mpc.mhe.crypto_params.params.slots()
    num_values = slots * 2 + slots // 2  # 2.5 ciphertexts worth
    
    with mpc.randomness.seed_switch(-1):
        values = random_floats((num_values,), scale=2.0)

    if mpc.pid > 0:
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)
        assert_eq(f"CP{mpc.pid}:\tMHE multi-cipher count", len(ciphervector), 3)
        
        secret_share = mpc.mhe.ciphervector_to_additive_share_vector(ciphervector, num_values, mpc_modulus, source_pid=1)
        ciphervector_back = mpc.mhe.additive_share_vector_to_ciphervector(secret_share, mpc_modulus, True)

        result = mpc.mhe.decode(enc=mpc.mhe.decrypt(ciphervector_back), dtype=float)
        stats = precision_stats(
            mpc=mpc,
            result=result[:num_values],
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tMHE<->MPC multi-ciphertext ({num_values} values)", stats.min_precision.l2 > 9, True)


def test_mhe_mpc_conversion_mpc_operations_on_shares(mpc, mpc_modulus):
    """Test that MPC operations work correctly on converted shares."""
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),), scale=2.0)

    if mpc.pid > 0:
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)
        secret_share = mpc.mhe.ciphervector_to_additive_share_vector(ciphervector, len(values), mpc_modulus, source_pid=1)
        
        # Add a public constant in MPC domain
        constant = 1.5
        constant_fp = double_to_fp(constant, mpc_modulus)
        share_plus_const = secret_share.add_mod(constant_fp if mpc.pid == mpc.comms.hub_pid else type(mpc_modulus)(0), mpc_modulus)
        
        # Convert back to ciphertext
        ciphervector_back = mpc.mhe.additive_share_vector_to_ciphervector(share_plus_const, mpc_modulus, True)

        expected = [v + constant for v in values]
        stats = precision_stats(
            mpc=mpc,
            result=mpc.mhe.decode(
                enc=mpc.mhe.decrypt(ciphervector_back),
                dtype=float),
            expected=expected)
        
        assert_eq(f"CP{mpc.pid}:\tMPC ops on MHE-converted shares", stats.min_precision.l2 > 9, True)


def test_mhe_mpc_conversion_from_different_sources(mpc, mpc_modulus):
    """Test conversion when ciphertext originates from different parties."""
    slots = mpc.mhe.crypto_params.params.slots()
    
    with mpc.randomness.seed_switch(-1):
        values = random_floats((slots,), scale=3.0)
    
    if mpc.pid > 0:
        # Test with source_pid = 1 (ciphertext at party 1)
        ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext) if mpc.pid == 1 else [ckks.NIL_IDEAL_CIPHERTEXT]
        secret_share = mpc.mhe.ciphervector_to_additive_share_vector(ciphervector, slots, mpc_modulus, source_pid=1)
        
        # Reveal and check
        revealed_sum = mpc.comms.reveal(secret_share, mpc_modulus)
        revealed_values = fp_to_double(revealed_sum, mpc_modulus)
        
        stats = precision_stats(
            mpc=mpc,
            result=revealed_values,
            expected=values)
        
        assert_eq(f"CP{mpc.pid}:\tMHE->MPC from source_pid=1", stats.min_precision.l2 > 10, True)


def test_mhe(mpc):
    print(f'CP{mpc.pid}:\tTesting MHE ... \n')

    test_send_receive_poly(mpc)
    test_send_receive_ciphertext(mpc)
    test_decryption(mpc)
    test_arithmetics(mpc)
    test_collective_bootstrapping(mpc)
    test_cipher_to_additive_plaintext_conversion(mpc)
    test_cipher_to_additive_share_vec_conversion(mpc, MPC_FIELD_SIZE)
    
    # Extended MHE<->MPC conversion tests
    test_mhe_mpc_conversion_additive_shares_sum_correctly(mpc, MPC_FIELD_SIZE)
    test_mhe_mpc_conversion_double_roundtrip(mpc, MPC_FIELD_SIZE)
    test_mhe_mpc_conversion_negative_values(mpc, MPC_FIELD_SIZE)
    test_mhe_mpc_conversion_partial_slots(mpc, MPC_FIELD_SIZE)
    test_mhe_mpc_conversion_multiple_ciphertexts(mpc, MPC_FIELD_SIZE)
    test_mhe_mpc_conversion_mpc_operations_on_shares(mpc, MPC_FIELD_SIZE)
    test_mhe_mpc_conversion_from_different_sources(mpc, MPC_FIELD_SIZE)
    
    # with mpc.default_modulus(MPC_RING_SIZE):
    #     test_cipher_to_additive_share_vec_conversion(mpc, MPC_RING_SIZE)

    print(f'CP{mpc.pid}:\tMHE tests passed.\n')
