from sequre.utils.testing import assert_eq
from sequre.utils.utils import __rand_mat
from sequre.constants import MPC_FIELD_SIZE
from sequre.utils.io import write_matrix, read_matrix


def test_io():
    print(f'Testing I/O ... \n')
    
    data_path = 'tests/data/temp.bin'
    rows, cols = 10, 10
    random_matrix = __rand_mat([rows, cols], MPC_FIELD_SIZE)
    
    with open(data_path, 'wb') as f:
        write_matrix(f, random_matrix, binary=True, TP=type(MPC_FIELD_SIZE))
    with open(data_path) as f:
        assert_eq('Binary file i/o', read_matrix(f, rows, cols, True, TP=type(MPC_FIELD_SIZE)), random_matrix)
    

def test_helpers():
    print(f'Testing helpers ... \n')
    
    test_io()
    
    print(f'Helpers tests passed.\n')
