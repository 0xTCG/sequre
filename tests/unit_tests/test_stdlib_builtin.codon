from numpy.create import array
from numpy.ndarray import ndarray

from sequre.attributes import sequre
from sequre.stdlib.builtin import (
    inv, chebyshev_sigmoid, chebyshev_log,
    chebyshev_mul_inv, chebyshev_sqrt, chebyshev_sqrt_inv)
from sequre.types.sharetensor import Sharetensor
from sequre.utils.testing import assert_eq_approx, assert_distributed_eq_approx, assert_eq
from sequre.utils.utils import random_floats


@sequre
def test_matrix_inverse(mpc, shape):
    alg_struct = "ring" if mpc.base_modulus.popcnt() == 1 else "field"
    matrix_raw = ndarray[Tuple[int, int], float].rand(shape, "uniform")
    matrix_stensor = Sharetensor.enc(mpc, matrix_raw)

    assert_eq_approx(
        f"CP{mpc.pid}:\tRaw matrix inverse on {alg_struct} for shape {shape}",
        matrix_raw @ inv(mpc, matrix_raw),
        matrix_raw.I, error=0.0001)
    assert_distributed_eq_approx(
        mpc, f"CP{mpc.pid}:\tSharetensor matrix inverse on {alg_struct} for shape {shape}",
        (matrix_stensor @ inv(mpc, matrix_stensor)).reveal(mpc),
        matrix_raw.I, error=0.001)


def test_chebyshev_op(mpc, msg, chebyshev_op, raw_mat, mpc_mat, mpp_mat, mpa_mat, expected_result, interval):
    alg_struct = "ring" if mpc.base_modulus.popcnt() == 1 else "field"
    
    mpc_result = chebyshev_op(mpc, mpc_mat, interval)
    mpp_result = chebyshev_op(mpc, mpp_mat, interval)
    mpa_result = chebyshev_op(mpc, mpa_mat, interval)
    
    assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tSequre {msg} (MPC) on {alg_struct}', mpc_result.reveal(mpc), expected_result, error=0.003)
    assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tMPC input intact post {msg} on {alg_struct}', mpc_mat.reveal(mpc), raw_mat, error=0.003, silent_pass=True)
    assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tSequre {msg} (MPP) on {alg_struct}', mpp_result.reveal(mpc), expected_result, error=0.003)
    assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tMPP input intact post {msg} on {alg_struct}', mpp_mat.reveal(mpc), raw_mat, error=0.003, silent_pass=True)
    assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tSequre {msg} (MPA) on {alg_struct}', mpa_result.reveal(mpc), expected_result, error=0.003)
    assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tMPU input intact post {msg} on {alg_struct}', mpa_mat.reveal(mpc), raw_mat, error=0.003, silent_pass=True)


def test_chebyshev(mpc):
    shape = (8 ,7)
    random_data_scale = 7
    interval = (1, random_data_scale + 1)
    modulus = mpc.base_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Chebyshev on {alg_struct} ... \n')
    
    with mpc.randomness.seed_switch(-1):
        raw_mat = array(random_floats(shape, scale=random_data_scale)) + 1
    
    mpc_mat = Sharetensor.enc(mpc, raw_mat, 0, modulus)
    mpp_mat = mpc_mat.to_mpp(mpc, [4, 4], dtype=float)
    mpa_mat = mpc_mat.to_mpa(mpc, dtype=float)

    test_chebyshev_op(
        mpc, "Chebyshev sigmoid",
        chebyshev_sigmoid, raw_mat, mpc_mat, mpp_mat, mpa_mat, raw_mat.sigmoid(), interval)
    test_chebyshev_op(
        mpc, "Chebyshev log",
        chebyshev_log, raw_mat, mpc_mat, mpp_mat, mpa_mat, raw_mat.log(), interval)
    test_chebyshev_op(
        mpc, "Chebyshev multiplicative inverse",
        chebyshev_mul_inv, raw_mat, mpc_mat, mpp_mat, mpa_mat, 1 / raw_mat, interval)
    test_chebyshev_op(
        mpc, "Chebyshev square root",
        chebyshev_sqrt, raw_mat, mpc_mat, mpp_mat, mpa_mat, raw_mat.sqrt(), interval)
    test_chebyshev_op(
        mpc, "Chebyshev multiplicative inverse of square root",
        chebyshev_sqrt_inv, raw_mat, mpc_mat, mpp_mat, mpa_mat, 1 / raw_mat.sqrt(), interval)
    

def test_stdlib_builtin(mpc):
    test_matrix_inverse(mpc, (2, 2))
    test_matrix_inverse(mpc, (3, 3))
    test_chebyshev(mpc)
    