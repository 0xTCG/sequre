################################### Wrappers #####################################
def lattiseq_wrapper(mpc, modulus):
    if mpc.pid != 0:
        print(f"CP{mpc.pid}: Lattiseq is benchmarked only at trusted dealer.")
        return
    log_path = "perf_lattiseq.txt"

    with perf_timing("Lattiseq setup", prefix=f"{datetime.now()} | ", log_path=log_path):
        params, encoder, encryptor, decryptor, evaluator, _ = lattiseq_test_setup()
        factor = [complex(i, i) for i in range(params.slots())]
    with perf_timing("Lattiseq encoding", log_path=log_path):
        plaintext = ckks.new_plaintext(params, params.max_level(), params.default_scale / 16)
        encoder.encode(factor, plaintext, params.log_slots)
    with perf_timing("Lattiseq encryption", log_path=log_path):
        ciphertext = encryptor.encrypt_new(plaintext)
    with perf_timing("Lattiseq cipher-plain multiplication w/o relinearization", log_path=log_path):
        cipher_prod = evaluator.mul_new(ciphertext, plaintext)
    with perf_timing("Lattiseq cipher-cipher multiplication w/o relinearization", log_path=log_path):
        cipher_prod = evaluator.mul_new(ciphertext, ciphertext)
    with perf_timing("Lattiseq cipher-plain multiplication w/ relinearization", log_path=log_path):
        cipher_prod = evaluator.mul_relin_new(ciphertext, plaintext)
    with perf_timing("Lattiseq cipher-cipher multiplication w/ relinearization", log_path=log_path):
        cipher_prod = evaluator.mul_relin_new(ciphertext, ciphertext)
    with perf_timing("Lattiseq cipher-cipher addition", log_path=log_path):
        cipher_cipher_sum = evaluator.add_new(cipher_prod, cipher_prod)
    with perf_timing("Lattiseq rotation", log_path=log_path):
        ciphertext_rotation = evaluator.rotate_new(cipher_cipher_sum, 1)
    with perf_timing("Lattiseq decryption", log_path=log_path):
        decrypted_plaintext = decryptor.decrypt_new(ciphertext_rotation)
    with perf_timing("Lattiseq decoding", " |\n", log_path=log_path):
        decoded_values = encoder.decode(decrypted_plaintext, params.log_slots)
    
    encryptor._mm_encrypt_zero(ciphertext)
    ckks_zeros_complex = encoder.decode(
        decryptor.decrypt_new(ciphertext),
        params.log_slots)
    ckks_zeros = [abs(e.real) for e in ckks_zeros_complex]
    ckks_zeros.extend([abs(e.imag) for e in ckks_zeros_complex])
    
    print(f"\nInput factor[:5]: {factor[:5]}")
    print(f"Decoded 2 * factor^2 shifted left [:5]: {decoded_values[:5]}")
    print(f"CKKS noise:\n\t\tMean: {ckks_zeros.mean()}\n\t\tMin: {min(ckks_zeros)}\n\t\tMax: {max(ckks_zeros)}\n")

def lattiseq_mult3_wrapper(mpc, modulus):
    if mpc.pid != 0:
        print(f"CP{mpc.pid}: Lattiseq mult3 is benchmarked only at trusted dealer.")
        return
    
    with timing("Lattiseq mult3 setup"):
        params, encoder, encryptor, decryptor, evaluator, _ = lattiseq_test_setup()
        x = [float(i) for i in range(params.slots())]
        y = [float(i * 2) for i in range(params.slots())]
        z = [float(i * 3) for i in range(params.slots())]
    with timing("Lattiseq mult3 encoding and encryption"):
        x_pt = ckks.new_plaintext(params, params.max_level(), params.default_scale / 16)
        y_pt = ckks.new_plaintext(params, params.max_level(), params.default_scale / 16)
        z_pt = ckks.new_plaintext(params, params.max_level(), params.default_scale / 16)
        encoder.encode(x, x_pt, params.log_slots)
        encoder.encode(y, y_pt, params.log_slots)
        encoder.encode(z, z_pt, params.log_slots)
        x_ct = encryptor.encrypt_new(x_pt)
        y_ct = encryptor.encrypt_new(y_pt)
        z_ct = encryptor.encrypt_new(z_pt)
    with timing("Lattiseq mult3 evaluation"):
        mul_1 = evaluator.mul_new(x_ct, y_ct)
        mul_2 = evaluator.mul_new(y_ct, z_ct)
        mul_3 = evaluator.mul_new(z_ct, x_ct)
        add_1 = evaluator.add_new(mul_1, mul_2)
        add_2 = evaluator.add_new(add_1, mul_3)
    with timing("Lattiseq mult3 decryption and decoding"):
        decrypted_plaintext = decryptor.decrypt_new(add_2)
        decoded_values = encoder.decode(decrypted_plaintext, params.log_slots)
    
    print(f"\tDecoded values [0:3]: {decoded_values[:3]}")

def mhe_wrapper(mpc, modulus):
    log_path = f"perf_mhe_CP{mpc.pid}.txt"
    with mpc.randomness.seed_switch(-1):
        values = random_floats((mpc.mhe.crypto_params.params.slots(),))
    
    if mpc.pid == 0:
        print(f"CP{mpc.pid}: Trusted dealer is not required while benchmarking collective MHE operations.")
        return
    
    ciphervector = mpc.mhe.enc_vector(values, T=ckks.Ciphertext)
    initial_level = ciphervector[0].level()

    mpc.mhe.crypto_params.evaluator.drop_level(ciphervector[0], initial_level - mpc.mhe.bootstrap_min_level - 1)
    ciphertext_bootstrapped = ciphervector[0].copy()

    with perf_timing("Bootstrap", prefix=f"\n{datetime.now()} | ", log_path=log_path):
        mpc.mhe._collective_bootstrap(ciphertext_bootstrapped, -1)
    
    ciphertext_bootstrapped = mpc.comms.broadcast_from(ciphertext_bootstrapped, mpc.comms.hub_pid)
    boot_lvl = ciphertext_bootstrapped.level()

    print(f"CP{mpc.pid}:\tMHE collective bootstrapping level (Bootstrapped level: {boot_lvl}. Initial level: {initial_level}. Reduced level: {ciphervector[0].level()})")
    
def king_wrapper(mpc, modulus):
    slots = mpc.mhe.crypto_params.params.slots()

    rows_per_party = 16
    snps_count = 145443
    cols = snps_count // slots * slots
    
    mpp_data = MPP.collective_load(
        mpc, f"data/king/1000_genomes_ph_3/partition_small_{mpc.pid}.bin",
        rows=rows_per_party, cols=cols, binary=True, dtype=int).astype(float)
    
    het_inv_scale = 1000
    het_inv = MPP.like(mpp_data, array([[(1 / row.count(1)) for _ in range(len(mpp_data))] for row in mpp_data], dtype=float))
    scaled_het_inv = het_inv * 1000

    return king(mpc, mpp_data, scaled_het_inv) / het_inv_scale

def king_mpc_wrapper(mpc, modulus):
    ins_per_party = 16
    rows = ins_per_party * (mpc.comms.number_of_parties - 1)
    snps_count = 145443
    cols = snps_count // 8192 * 8192
    
    if mpc.pid:
        with open(f"data/king/1000_genomes_ph_3/partition_small_{mpc.pid}.bin") as f:
            raw_data = read_ndarray(f, (ins_per_party, cols), True, dtype=float)
            raw_het_inv = array([[(1 / row.count(1)) for _ in range(rows)] for row in raw_data], dtype=float)
    else:
        raw_data = zeros((ins_per_party, cols), dtype=float)
        raw_het_inv = zeros((ins_per_party, rows), dtype=float)
    
    mpc_data = Sharetensor(list[list[mpc_uint]](rows), modulus)
    mpc_data.fp = True
    for p in range(1, mpc.comms.number_of_parties):
        mpc_data.extend(Sharetensor.enc(mpc, raw_data, p, modulus))
    
    mpc_het_inv = Sharetensor(list[list[mpc_uint]](rows), modulus)
    mpc_het_inv.fp = True
    for p in range(1, mpc.comms.number_of_parties):
        mpc_het_inv.extend(Sharetensor.enc(mpc, raw_het_inv, p, modulus))
    
    return king(mpc, mpc_data, mpc_het_inv)

def pca_wrapper(mpc, modulus):
    def _project(mpc, components, data):
        w = orthonormalize(mpc, components.reveal(mpc) @ data)
        return (w @ data.T).T
    
    rows_per_party = 16
    rows = rows_per_party * (mpc.comms.number_of_parties - 1)
    cols = 1 << 15

    top_components_count = 2
    oversampling_count = 2
    power_iterations_count = 10

    raw_data = loadtxt("data/lung/filtered_dosage.txt", shape=(rows, cols), dtype=float)
    # Scale data to avoid overflow
    raw_data -= raw_data.mean(axis=0)
    raw_data /= 1024
    
    local_data = raw_data[(mpc.pid - 1) * rows_per_party:mpc.pid * rows_per_party] if mpc.pid else raw_data.zeros()
    mpc_data = Sharetensor.enc(mpc, raw_data, 0, modulus)
    mp_data = MPU(mpc, local_data, "partition")
    
    mpc.randomness.reset_seed(-1, hash('global'))
    with timing("Raw PCA"):
        raw_y = random_pca_experimental(
            mpc, raw_data, top_components_count, oversampling_count,
            power_iterations_count, rows_per_party)
    
    log("", raw_y.tolist(), path='results/raw_pca_components.txt', mode='w', separator=' ')
    raw_projection = _project(mpc, raw_y, raw_data)
    log("", raw_projection.tolist(), path='results/raw_pca_projection.txt', mode='w', separator=' ')

    mpc.randomness.reset_seed(-1, hash('global'))
    with timing("Sequre PCA"):
        mpc_y = random_pca_experimental(
            mpc, mpc_data, top_components_count, oversampling_count,
            power_iterations_count, rows_per_party)
    
    log("", mpc_y.reveal(mpc).tolist(), path='results/mpc_pca_components.txt', mode='w', separator=' ')
    mpc_projection = _project(mpc, mpc_y, raw_data)
    log("", mpc_projection.tolist(), path='results/mpc_pca_projection.txt', mode='w', separator=' ')

    mpc.randomness.reset_seed(-1, hash('global'))
    with timing("SheQi PCA"):
        mp_y = random_pca_experimental(
            mpc, mp_data, top_components_count, oversampling_count,
            power_iterations_count, rows_per_party)
    
    log("", mp_y.reveal().tolist(), path='results/mp_pca_components.txt', mode='w', separator=' ')
    mp_projection = _project(mpc, mp_y, raw_data)
    log("", mp_projection.tolist(), path='results/mhe_pca_projection.txt', mode='w', separator=' ')

    return mp_projection

def lin_alg_wrapper(mpc, modulus, sv_mat):
    # return qr_fact_square(mpc, sv_mat)
    # return tridiag(mpc, sv_mat)
    # return eigen_decomp(mpc, sv_mat)
    # return orthonormalize(mpc, sv_mat)
    return l2(mpc, sv_mat)

def mi_wrapper(mpc, modulus):
    im_epochs = 40
    fm_epochs = 40
    im_noise_scale = 0.01
    mi_factor = 5
    dump_data = True

    simice_rows = 500
    simice_cols = 10
    
    scenarios_runs_count = 10
    scenarios_rows = 500
    scenarios_cols = 2
    scenarios_miss_col = 0

    real_setup_runs_count = 1

    verbose = False
    run_simice_scenarios = True
    run_paper_scenarios = True
    run_real_setup = True
    
    benchmark_mi(mpc, mi_factor, im_epochs, fm_epochs, im_noise_scale,
                 dump_data, scenarios_runs_count, scenarios_rows,
                 scenarios_cols, simice_rows, simice_cols, scenarios_miss_col,
                 real_setup_runs_count, verbose, run_simice_scenarios,
                 run_paper_scenarios, run_real_setup, modulus)

def gwas_mpc_wrapper(mpc, modulus):
    share_data(mpc, "gwas", modulus)
    return gwas_protocol(mpc, modulus)
    
def gwas_mhe_wrapper(mpc, modulus):
    return sf_gwas_experimental(mpc, modulus)

def gwas_wrapper(mpc, modulus):
    gwas_mpc_wrapper(mpc, modulus)
    return gwas_mhe_wrapper(mpc, modulus)

def genotype_imputation_wrapper(mpc, modulus):
    return genotype_imputation(mpc, modulus)

def dti_wrapper(mpc, modulus):
    with mpc.default_encoding(ENC_DIAG):
        return dti_mhe_protocol(mpc)
    # return dti_mpc_protocol(mpc, True, modulus, False)

def opal_wrapper(mpc, modulus, coverage):
    opal(mpc, modulus, coverage)[0]

def ganon_wrapper(mpc, modulus, read_limit):
    parsed_hierarchy = {
        "level_1": {
                "window_size": 0,
                "kmer_size": 19,
                "offset": 1,
                "rel_filter": 1,
                "abs_filter": 0,
                "alphabet_size": 5  # the size of the nucleotide alphabeth -- 5 in case of SeqAn's IBF (A,C,G,N,T)
            }
        }

    filter_config = FilterConfig(
        ibf_path="data/ganon/opal_dataset_ibf.bin",
        map_path="data/ganon/opal_dataset_map.txt",
        rel_cutoff=0.25,
        abs_cutoff=0.0,
        bin_count=63,
        hash_count=4)

    ganon(mpc, parsed_hierarchy, [filter_config], 'tests/data/opal/test.fragments.fasta', modulus, read_limit)

##################################################################################


def benchmark[TP](mpc, benchmark_toggles: dict, modulus: TP):
    h_mat = [[double_to_fp(float(i + j), modulus) for i in range(50)] for j in range(50)]
    sv_mat = Sharetensor(h_mat, modulus)
    sv_mat.get_partitions(mpc)
    sv_mat.fp = True

    mpc.comms.sync_parties()
    run_all = benchmark_toggles[RUN_TOGGLES.RUN_ALL_FLAG]

    if benchmark_toggles[RUN_TOGGLES.LATTISEQ_FLAG] or run_all:
        time_frame(mpc, lattiseq_wrapper, 'Lattiseq', modulus)
    if benchmark_toggles[RUN_TOGGLES.LATTISEQ_MULT3_FLAG] or run_all:
        time_frame(mpc, lattiseq_mult3_wrapper, 'Lattiseq mult3', modulus)
    if benchmark_toggles[RUN_TOGGLES.MHE_FLAG] or run_all:
        time_frame(mpc, mhe_wrapper, 'MHE', modulus)
    if benchmark_toggles[RUN_TOGGLES.KING_FLAG] or run_all:
        time_frame(mpc, king_wrapper, 'KING', modulus)
    if benchmark_toggles[RUN_TOGGLES.KING_MPC_FLAG] or run_all:
        time_frame(mpc, king_mpc_wrapper, 'KING-MPC', modulus)
    if benchmark_toggles[RUN_TOGGLES.MI_FLAG] or run_all:
        time_frame(mpc, mi_wrapper, 'Multiple imputation', modulus)
    if benchmark_toggles[RUN_TOGGLES.PCA_FLAG] or run_all:
        time_frame(mpc, pca_wrapper, 'PCA', modulus)

    if benchmark_toggles[RUN_TOGGLES.LIN_ALG_FLAG] or run_all:
        time_frame(mpc, lin_alg_wrapper, 'Linear algebra', modulus, sv_mat)
    if benchmark_toggles[RUN_TOGGLES.GWAS_MPC_FLAG] or run_all:
        time_frame(mpc, gwas_mpc_wrapper, 'Genome-wide association study (MPC)', modulus)
    if benchmark_toggles[RUN_TOGGLES.GWAS_MHE_FLAG] or run_all:
        time_frame(mpc, gwas_mhe_wrapper, 'Genome-wide association study (MHE)', modulus)
    if benchmark_toggles[RUN_TOGGLES.GWAS_FLAG] or run_all:
        time_frame(mpc, gwas_wrapper, 'Genome-wide association study (MPC and MHE)', modulus)
    if benchmark_toggles[RUN_TOGGLES.DTI_FLAG] or run_all:
        time_frame(mpc, dti_wrapper, 'Drug target interaction inference', modulus)
    if benchmark_toggles[RUN_TOGGLES.OPAL_FLAG] or run_all:
        time_frame(mpc, opal_wrapper, 'Opal 0.1x', modulus, 0.1)
        time_frame(mpc, opal_wrapper, 'Opal 15x', modulus, 15)
    if benchmark_toggles[RUN_TOGGLES.GANON_FLAG] or run_all:
        time_frame(mpc, ganon_wrapper, 'Ganon', modulus, 100)
    if benchmark_toggles[RUN_TOGGLES.GENOTYPE_IMPUTATION_FLAG] or run_all:
        time_frame(mpc, genotype_imputation_wrapper, 'Genotype imputation', modulus)

    mpc.comms.sequential(perf_print_stats, False, f"CP{mpc.pid}: ")
