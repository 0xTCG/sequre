    im_epochs = 40
    fm_epochs = 40
    im_noise_scale = 0.01
    mi_factor = 2
    dump_data = True

    simice_rows = 500
    simice_cols = 10
    
    scenarios_runs_count = 1
    scenarios_rows = 500
    scenarios_cols = 2
    scenarios_miss_col = 0

    real_setup_runs_count = 1

    verbose = False
    run_simice_scenarios = True
    run_paper_scenarios = True
    run_real_setup = False

    backend: Static[str] = "sheqi"
    
    # with mpc.default_encoding(ENC_DIAG):
