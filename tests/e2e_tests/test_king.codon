from time import timing

from numpy.create import array, zeros_like

from sequre.types.sharetensor import Sharetensor
from sequre.types.multiparty_partition import MPP
from sequre.utils.testing import assert_eq, assert_eq_approx
from sequre.utils.utils import random_ints
from sequre.constants import *
from sequre.mpc.env import MPCEnv
from .. import king


def test_king[TP](mpc: MPCEnv[TP], modulus: TP):
    print(f'CP{mpc.pid}:\tTesting Sequre KING on {"ring" if modulus.popcnt() == 1 else "field"} ... \n')

    rows_per_partition, cols = 16, 8192 # 278528
    het_inv_scale = cols // 100
    rows = rows_per_partition * (mpc.comms.number_of_parties - 1)
    
    # Generate data
    with mpc.randomness.seed_switch(-1):
        raw_data = array(random_ints((rows, cols), 0, 2), dtype=float)
    raw_data_partition = zeros_like(raw_data) if mpc.pid == 0 else raw_data[(mpc.pid - 1) * rows_per_partition:mpc.pid * rows_per_partition]
    sequre_data = Sharetensor.enc(mpc, raw_data)
    sheqi_data = MPP(mpc, raw_data_partition)
    
    # Upscale het_inv by het_inv_scale to reduce the impact of CKKS noise
    raw_het_inv = array([[(1 / row.count(1)) for _ in range(rows)] for row in raw_data], dtype=float) * het_inv_scale
    raw_het_inv_partition = zeros_like(raw_het_inv) if mpc.pid == 0 else raw_het_inv[(mpc.pid - 1) * rows_per_partition:mpc.pid * rows_per_partition]
    sequre_het_inv = Sharetensor.enc(mpc, raw_het_inv)
    sheqi_het_inv = MPP(mpc, raw_het_inv_partition)
    
    mpc.comms.sequential(lambda: print(f"CP{mpc.pid}: KING test data for debugging:", raw_data.tolist().abbrv()), False)
    if mpc.pid > 0:
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking KING data loading: Sequre data", sequre_data.reveal(mpc), raw_data)
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking KING data loading: Sequre het_inv", sequre_het_inv.reveal(mpc), raw_het_inv)
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking KING data loading: SheQi data", sheqi_data.reveal(mpc), raw_data)
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking KING data loading: SheQi het_inv", sheqi_het_inv.reveal(mpc), raw_het_inv)

    with timing(f"Raw KING at CP{mpc.pid}"):
        classic_king_coefficients = king(mpc, raw_data, raw_het_inv)
    with timing(f"Sequre KING at CP{mpc.pid}"):
        sequre_king_coefficients = king(mpc, sequre_data, sequre_het_inv)
    with timing(f"SheQi KING at CP{mpc.pid}"):
        sheqi_king_coefficients = king(mpc, sheqi_data, sheqi_het_inv)

    if mpc.pid == 0:
        assert_eq(f"CP{mpc.pid}:\tSafe-checking KING result shape (Sequre)", sequre_king_coefficients.shape, list(classic_king_coefficients.shape))
        assert_eq(f"CP{mpc.pid}:\tSafe-checking KING result shape (SheQi)", sheqi_king_coefficients.shape, classic_king_coefficients.shape)
    else:
        # assert_eq_approx(f"CP{mpc.pid}:\tSequre KING", sequre_king_coefficients.reveal(mpc) / het_inv_scale, classic_king_coefficients / het_inv_scale)
        assert_eq_approx(f"CP{mpc.pid}:\tSheQi KING", sheqi_king_coefficients.reveal(mpc) / het_inv_scale, classic_king_coefficients / het_inv_scale)

    print(f'CP{mpc.pid}:\tKING on {"ring" if modulus.popcnt() == 1 else "field"} tests passed.\n')
    