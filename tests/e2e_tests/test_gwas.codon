from numpy.create import zeros_like, array

from sequre.types.sharetensor import Sharetensor
from sequre.types.multiparty_union import MPU
from sequre.utils.testing import assert_eq, assert_eq_approx
from sequre.utils.utils import random_ints, random_floats

from .. import \
    cochran_armitage, \
    gwas_protocol, \
    sf_gwas_experimental


def test_cochran_armitage(mpc, modulus):
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Cochran-Armitage on {alg_struct} ... \n')

    inds_per_party = 8
    inds_count = inds_per_party * (mpc.comms.number_of_parties - 1)
    snps_count = 32
    pca_components_count = 4
    
    with mpc.randomness.seed_switch(-1):
        raw_pca_components = array(random_floats((pca_components_count, inds_count), scale=1))
        raw_pheno = array(random_ints((inds_count,), upper_limit=1), dtype=float)
        raw_dosage = array(random_ints((inds_count, snps_count), upper_limit=2), dtype=float)
        raw_dosage -= raw_dosage.mean(axis=0)
    
    mpc_pca_components = Sharetensor.enc(mpc, raw_pca_components, 1, modulus)
    mpc_pheno = Sharetensor.enc(mpc, raw_pheno, 1, modulus)
    mpc_dosage = Sharetensor.enc(mpc, raw_dosage, 1, modulus)

    partition_pca_components = raw_pca_components.T[(mpc.pid - 1) * inds_per_party: mpc.pid * inds_per_party] if mpc.pid else zeros_like(raw_pca_components).T
    partition_pheno = raw_pheno[(mpc.pid - 1) * inds_per_party: mpc.pid * inds_per_party] if mpc.pid else zeros_like(raw_pheno)
    partition_dosage = raw_dosage[(mpc.pid - 1) * inds_per_party: mpc.pid * inds_per_party] if mpc.pid else zeros_like(raw_dosage)
    
    mpu_pca_components = MPU[Tuple[int, int], float](mpc, partition_pca_components, "partition").T
    mpu_pheno = MPU[Tuple[int], float](mpc, partition_pheno, "partition").T
    mpu_dosage = MPU[Tuple[int, int], float](mpc, partition_dosage, "partition")

    mpc.comms.sequential(lambda: print(f"CP{mpc.pid}:\tCochran-Armitage test data for debugging on {alg_struct}: components", raw_pca_components.tolist()), False)
    if mpc.pid == 0:
        assert_eq(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading shapes (MPC) on {alg_struct}: components", mpc_pca_components.shape, list(raw_pca_components.shape))
        assert_eq(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading shapes (MPU) on {alg_struct}: components", mpu_pca_components.shape, raw_pca_components.shape)
    else:
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading (MPC) on {alg_struct}: components", mpc_pca_components.reveal(mpc).tolist(), raw_pca_components.tolist())
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading (MPU) on {alg_struct}: components", mpu_pca_components.reveal(mpc).tolist(), raw_pca_components.tolist())
    
    mpc.comms.sequential(lambda: print(f"CP{mpc.pid}:\tCochran-Armitage test data for debugging on {alg_struct}: pheno", raw_pheno.tolist()), False)
    if mpc.pid == 0:
        assert_eq(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading shapes (MPC) on {alg_struct}: pheno", mpc_pheno.shape, list(raw_pheno.shape))
        assert_eq(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading shapes (MPU) on {alg_struct}: pheno", mpu_pheno.shape, raw_pheno.shape)
    else:
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading (MPC) on {alg_struct}: pheno", mpc_pheno.reveal(mpc).tolist(), raw_pheno.tolist())
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading (MPU) on {alg_struct}: pheno", mpu_pheno.reveal(mpc).tolist(), raw_pheno.tolist())
    
    mpc.comms.sequential(lambda: print(f"CP{mpc.pid}:\tCochran-Armitage test data for debugging on {alg_struct}: geno", raw_dosage.tolist()), False)
    if mpc.pid == 0:
        assert_eq(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading shapes (MPC) on {alg_struct}: geno", mpc_dosage.shape, list(raw_dosage.shape))
        assert_eq(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading shapes (MPU) on {alg_struct}: geno", mpu_dosage.shape, raw_dosage.shape)
    else:
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading (MPC) on {alg_struct}: geno", mpc_dosage.reveal(mpc).tolist(), raw_dosage.tolist())
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage data loading (MPU) on {alg_struct}: geno", mpu_dosage.reveal(mpc).tolist(), raw_dosage.tolist())

    raw_assoc = cochran_armitage(mpc, raw_pca_components, raw_pheno, raw_dosage).nan_to_num()
    mpc_assoc = cochran_armitage(mpc, mpc_pca_components, mpc_pheno, mpc_dosage)

    if mpc.pid == 0:
        assert_eq(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage result shape (MPC) on {alg_struct}", mpc_assoc.shape, list(raw_assoc.shape))
    else:
        assert_eq_approx(f"CP{mpc.pid}:\tSequre Cochran-Armitage (MPC) on {alg_struct}", (mpc_assoc.reveal(mpc) * raw_assoc).tolist(), (raw_assoc * raw_assoc).tolist())
    
    mpu_assoc = cochran_armitage(mpc, mpu_pca_components, mpu_pheno, mpu_dosage)

    if mpc.pid == 0:
        assert_eq(f"CP{mpc.pid}:\tSafe-checking Cochran-Armitage result shape (MPU) on {alg_struct}", mpu_assoc.shape, raw_assoc.shape)
    else:
        assert_eq_approx(f"CP{mpc.pid}:\tSequre Cochran-Armitage (MPU) on {alg_struct}", (mpu_assoc.reveal(mpc) * raw_assoc).tolist(), (raw_assoc * raw_assoc).tolist(), error=0.5)
    
    print(f'CP{mpc.pid}:\tSequre Cochran-Armitage on {"ring" if modulus.popcnt() == 1 else "field"} tests passed.\n')


def test_gwas_sections(mpc, modulus):
    print(f'CP{mpc.pid}:\tTesting Sequre GWAS sections on {"ring" if modulus.popcnt() == 1 else "field"} ... \n')
    
    test_cochran_armitage(mpc, modulus)

    print(f'CP{mpc.pid}:\tSequre GWAS sections on {"ring" if modulus.popcnt() == 1 else "field"} tests passed.\n')


def test_gwas_mpc(mpc, modulus):
    print(f'CP{mpc.pid}:\tTesting Sequre GWAS-MPC on {"ring" if modulus.popcnt() == 1 else "field"} ... \n')

    with open('tests/data/output/gwas.txt') as f:
        expected_output = [float(e.strip()) for e in next(f).split(',')]
        gwas_result = mpc.comms.print_fp(gwas_protocol(mpc, modulus).share, modulus)
        if mpc.pid:
            assert_eq_approx(f'CP{mpc.pid}:\tSequre GWAS-MPC ({"ring" if modulus.popcnt() == 1 else "field"})', gwas_result, expected_output, error=0.05)

    print(f'CP{mpc.pid}:\tSequre GWAS-MPC on {"ring" if modulus.popcnt() == 1 else "field"} tests passed.\n')


def test_gwas_mhe(mpc, modulus):
    print(f'CP{mpc.pid}:\tTesting Sequre GWAS-MHE on {"ring" if modulus.popcnt() == 1 else "field"} ... \n')
    sf_gwas_experimental(mpc, modulus)


def test_gwas(mpc, modulus):
    test_gwas_mpc(mpc, modulus)
    test_gwas_sections(mpc, modulus)
    # test_gwas_mhe(mpc, modulus)
