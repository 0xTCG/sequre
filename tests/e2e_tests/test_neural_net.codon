from numpy.create import array, zeros, zeros_like, ones
from sequre.types.sharetensor import Sharetensor
from sequre.types.multiparty_union import MPU
from sequre.utils.testing import assert_eq, assert_eq_approx
from sequre.utils.utils import random_floats, random_ints
from sequre.mpc.env import MPCEnv
from sequre.stdlib.learn.neural_net.model import Sequential
from sequre.stdlib.learn.neural_net.layers import Input, Dense, Conv2D, Flatten
from sequre.stdlib.learn.neural_net.loss import dloss
from sequre import sequre
from sequre.stdlib.builtin import maximum


@sequre
def _sequre_matmul(mpc, a, b):
    return a @ b

@sequre
def _sequre_maximum(mpc, a, b):
    return maximum(mpc, a, b)

def _test_neural_net_cnn[TP](mpc: MPCEnv[TP], modulus: TP):
    """
    End-to-end test for CNN with mean_squared_error loss.
    """
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre CNN layers on {alg_struct} ... \n')

    N = 4                  # Batch Size
    H, W, C_in = 8, 8, 1   # Height, Width, Channels of input
    n_filters = 4          # Number of Conv2D filters
    dense_out = 2          # Output size of Dense layer
    step = 0.01            # Step size for training
    momentum = 0.9         # Momentum for training
    epochs = 2             # Number of training epochs

    ndarray_4d = type(zeros((1, 1, 1, 1)))
    ndarray_2d = type(zeros((1, 1)))

    # Conv2D output spatial dims (stride = 1)
    kH, kW = 3, 3                           # Kernel Size
    out_H = (H - kH) + 1                    # Output Height
    out_W = (W - kW) + 1                    # Output Width
    flat_size = out_H * out_W * n_filters   # Total no of elements per sample

    # Build input data
    with mpc.randomness.seed_switch(-1):
        X = zeros((N, H, W, C_in))
        for i in range(N):
            for j in range(min(H, W)):
                X[i, j, j, 0] = float(i + 1)
    y = ones((N, dense_out))
    """
    Make first half of labels -1, second half +1. This way we can check if the model is learning to separate the two halves after training.
    """
    for i in range(N // 2):
        y[i, 0] = -1.0

    # Build layers
    inp = Input[ndarray_4d](H * W * C_in)                                                           # Input Layer
    conv = Conv2D[ndarray_4d]("relu", out_channels=n_filters, kernel_size=(kH, kW), stride=(1, 1))  # Conv2D Layer
    conv.initialize(mpc, C_in)
    flat = Flatten[ndarray_4d, ndarray_2d]()                                                        # Flatten Layer
    dense = Dense[ndarray_2d]("linear", size=dense_out)                                             # Dense Layer
    dense.initialize(mpc, flat_size)

    # Record initial conv weight sum
    w0_sum = conv.weights.reshape((conv.weights.size,)).sum()

    # Training loop — track loss at first and last epoch
    loss_first = 0.0
    loss_last = 0.0
    for ep in range(epochs):
        inp.evaluate(mpc, X)
        # Forward Pass
        conv.evaluate(mpc, inp.output)      # Conv2D Forward Pass
        flat.evaluate(mpc, conv.output)
        dense.evaluate(mpc, flat.output)    # Dense Forward Pass

        # Compute MSE loss for this epoch
        diff = y - dense.output
        epoch_loss = (diff * diff).sum() / (2.0 * N)
        if ep == 0:
            loss_first = epoch_loss
        loss_last = epoch_loss

        # Backward Pass
        g = dloss(mpc, y, dense.output, "mean_squared_error")
        g = dense.derive(mpc, flat.output, g, LAYER_IDX=4)
        g = flat.derive(mpc, conv.output, g, LAYER_IDX=3)
        conv.derive(mpc, inp.output, g, LAYER_IDX=1)
        conv.update(mpc, step, momentum)
        dense.update(mpc, step, momentum)

    # Conv weights after training
    w1_sum = conv.weights.reshape((conv.weights.size,)).sum()

    # Shape assertions
    assert_eq(f"CP{mpc.pid}:\tCNN Conv2D output shape on {alg_struct}", list(conv.output.shape), [N, out_H, out_W, n_filters])
    assert_eq(f"CP{mpc.pid}:\tCNN Flatten output shape on {alg_struct}", list(flat.output.shape), [N, flat_size])
    assert_eq(f"CP{mpc.pid}:\tCNN Dense output shape on {alg_struct}", list(dense.output.shape), [N, dense_out])

    # Weights must change after training
    assert w0_sum != w1_sum, f"CP{mpc.pid}: Conv2D weights unchanged after training"

    # Loss must decrease after training
    assert loss_last < loss_first, f"CP{mpc.pid}: CNN loss did not drop (first={loss_first}, last={loss_last})"
    print(f'CP{mpc.pid}:\tCNN loss dropped: {loss_first:.4f} -> {loss_last:.4f}')
    print(f'CP{mpc.pid}:\tSequre CNN layers on {alg_struct} tests passed.\n')

def _test_conv2d[TP](mpc: MPCEnv[TP], modulus: TP):
    """
    Convolution step on a single 2D matrix
    """
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Conv2D 2D matmul component on {alg_struct} ... \n')

    # A small 2D "patch" (4 samples x 3 input channels)
    with mpc.randomness.seed_switch(-1):
        patch = array([[0.5, 0.3, 0.1],
                       [0.2, 0.8, 0.4],
                       [0.9, 0.1, 0.6],
                       [0.3, 0.7, 0.2]])
        # Weight matrix (3 input channels x 2 output filters)
        weights = array([[0.1, -0.2],
                         [0.3,  0.4],
                         [-0.1, 0.5]])

    # Plaintext Conv2D
    raw_result = patch @ weights

    # Encrypted Conv2D
    mpc_patch = Sharetensor.enc(mpc, patch, 0, modulus)
    mpc_weights = Sharetensor.enc(mpc, weights, 0, modulus)
    mpc_result = _sequre_matmul(mpc, mpc_patch, mpc_weights)

    if mpc.pid == 0:
        assert_eq(f"CP{mpc.pid}:\tConv2D matmul shape on {alg_struct}",
                  mpc_result.shape, list(raw_result.shape))
    else:
        assert_eq_approx(f"CP{mpc.pid}:\tConv2D 2D matmul on {alg_struct}",
                         mpc_result.reveal(mpc), raw_result, error=0.1)
    print(f'CP{mpc.pid}:\tConv2D 2D matmul component on {alg_struct} passed.\n')


def _test_maxpool2d[TP](mpc: MPCEnv[TP], modulus: TP):
    """
    Max-pooling on a 2D matrix.
    """
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting MaxPool2D component on {alg_struct} ... \n')

    # 4x4 input matrix
    with mpc.randomness.seed_switch(-1):
        mat = array([[1.0, 3.0, 2.0, 4.0],
                     [5.0, 2.0, 8.0, 1.0],
                     [3.0, 7.0, 6.0, 0.0],
                     [9.0, 4.0, 2.0, 5.0]])

    # Expected 2x2 max-pooling with pool_size=2, stride=2:
    #   top-left  pool: max(1,3,5,2) = 5
    #   top-right pool: max(2,4,8,1) = 8
    #   bottom-left  pool: max(3,7,9,4) = 9
    #   bottom-right pool: max(6,0,2,5) = 6
    raw_result = array([[5.0, 8.0],
                        [9.0, 6.0]])

    # Plaintext maxpool
    pH, pW = 2, 2
    out_H, out_W = 2, 2
    plain_out = zeros((out_H, out_W))
    for oh in range(out_H):
        for ow in range(out_W):
            h_s = oh * pH
            w_s = ow * pW
            max_val = mat[h_s, w_s]
            for i in range(pH):
                for j in range(pW):
                    max_val = _sequre_maximum(mpc, max_val, mat[h_s + i, w_s + j])
            plain_out[oh, ow] = max_val
    assert_eq_approx(f"CP{mpc.pid}:\tMaxPool2D plaintext on {alg_struct}",
                     plain_out, raw_result, error=0.01)

    # Encrypted maxpool
    mpc_mat = Sharetensor.enc(mpc, mat, 0, modulus)
    mpc_out_rows = list[list[float]]()
    for oh in range(out_H):
        row = list[float]()
        for ow in range(out_W):
            h_s = oh * pH
            w_s = ow * pW
            max_val = mpc_mat[h_s][w_s]
            for i in range(pH):
                for j in range(pW):
                    max_val = _sequre_maximum(mpc, max_val, mpc_mat[h_s + i][w_s + j])
            row.append(max_val.reveal(mpc))
        mpc_out_rows.append(row)
    mpc_out = array(mpc_out_rows)

    if mpc.pid > 0:
        assert_eq_approx(f"CP{mpc.pid}:\tMaxPool2D sequre on {alg_struct}",
                         mpc_out, raw_result, error=0.1)
    print(f'CP{mpc.pid}:\tMaxPool2D component on {alg_struct} passed.\n')

def test_neural_net[TP](mpc: MPCEnv[TP], modulus: TP):
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre neural net on {alg_struct} ... \n')

    input_size = 16
    output_size = 1
    n_neurons = 32
    step_size = 0.2
    epochs = 2
    momentum = 0.9
    
    rows_per_party = 4
    rows = (mpc.comms.number_of_parties - 1) * rows_per_party
    cols = input_size
    with mpc.randomness.seed_switch(-1):
        X = array(random_floats((rows, cols), scale=1.0))
        y = (array(random_ints((rows, output_size), upper_limit=1)) * 2 - 1).astype(float)

    mpc_X = Sharetensor.enc(mpc, X, 0, modulus)
    mpc_y = Sharetensor.enc(mpc, y, 0, modulus)
    
    partition_X = zeros_like(X) if mpc.pid == 0 else X[(mpc.pid - 1) * rows_per_party:mpc.pid * rows_per_party]
    partition_y = zeros_like(y) if mpc.pid == 0 else y[(mpc.pid - 1) * rows_per_party:mpc.pid * rows_per_party]
    
    mpu_X = MPU(mpc, partition_X, "partition")
    mpu_y = MPU(mpc, partition_y, "partition")

    mpc.comms.sequential(lambda: print(f"CP{mpc.pid}:\tNeural net train data for debugging on {alg_struct}:", X), False)
    if mpc.pid > 0:
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking neural net data loading (MPC) on {alg_struct}", mpc_X.reveal(mpc), X)
        assert_eq_approx(f"CP{mpc.pid}:\tSafe-checking neural net data loading (MPU) on {alg_struct}", mpu_X.reveal(mpc), X)
    
    raw_layers = (
        Input[type(X)](input_size),
        Dense[type(X)]("relu", n_neurons, "normal", "zeros"),
        Dense[type(X)]("linear", output_size, "normal", "zeros"))
    mpc.randomness.reset_seed(-1, hash('global'))
    with mpc.randomness.seed_switch(-1):
        raw_model = Sequential(raw_layers).compile(mpc, loss="hinge", optimizer="bgd")
    raw_model.fit(mpc, X=X, y=y, step=step_size, epochs=epochs, momentum=momentum)
    raw_w = raw_model.layers[1].weights

    mpc_layers = (
        Input[type(mpc_X)](input_size),
        Dense[type(mpc_X)]("relu", n_neurons, "normal", "zeros"),
        Dense[type(mpc_X)]("linear", output_size, "normal", "zeros"))
    mpc.randomness.reset_seed(-1, hash('global'))
    with mpc.randomness.seed_switch(-1):
        mpc_model = Sequential(mpc_layers).compile(mpc, loss="hinge", optimizer="bgd", modulus=modulus)
    mpc_model.fit(mpc, X=mpc_X, y=mpc_y, step=step_size, epochs=epochs, momentum=momentum)
    mpc_w = mpc_model.layers[1].weights

    if mpc.pid == 0:
        assert_eq(f"CP{mpc.pid}:\tSafe-checking neural net result shape (MPC) on {alg_struct}", mpc_w.shape, list(raw_w.shape))
    else:
        assert_eq_approx(f"CP{mpc.pid}:\tSequre neural net (MPC) on {alg_struct}", mpc_w.reveal(mpc), raw_w, error=0.3)
    
    _test_neural_net_cnn(mpc, modulus)
    _test_conv2d(mpc, modulus)
    _test_maxpool2d(mpc, modulus)

    mpu_layers = (
        Input[type(mpu_X)](input_size),
        Dense[type(mpu_X)]("relu", n_neurons, "normal", "zeros"),
        Dense[type(mpu_X)]("linear", output_size, "normal", "zeros"))
    mpc.randomness.reset_seed(-1, hash('global'))
    with mpc.randomness.seed_switch(-1):
        mpu_model = Sequential(mpu_layers).compile(mpc, loss="hinge", optimizer="bgd")
    mpu_model.fit(mpc, X=mpu_X, y=mpu_y, step=step_size, epochs=epochs, momentum=momentum)
    mpu_w = mpu_model.layers[1].weights

    if mpc.pid == 0:
        assert_eq(f"CP{mpc.pid}:\tSafe-checking neural net result shape (MPU) on {alg_struct}", mpu_w.shape, raw_w.shape)
    else:
        assert_eq_approx(f"CP{mpc.pid}:\tSequre neural net (MPU) on {alg_struct}", mpu_w.reveal(mpc), raw_w)

    print(f'CP{mpc.pid}:\tSequre neural net on {alg_struct} tests passed.\n')
