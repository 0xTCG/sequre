sfix.set_precision(32, 64)

m = 1
n = 8192

M = Matrix(m, n, sfix)
for i in range(m):
    for j in range(n):
        M[i][j] = sfix.get_input_from(0) + 0.1

rev_M = Matrix(m, n, cfix)
for i in range(m):
    for j in range(n):
        rev_M[i][j] = M[i][j].reveal()

print_ln('Res: %s, Op: %s', M[0][0].reveal(), M[0][1].reveal())
