sfix.set_precision(32, 64)

m = 1
n = 8192

M = Matrix(m, n, sfix)

for i in range(m):
    for j in range(n):
        M[i][j] = sfix.get_input_from(0) + 0.1

decomp = Matrix(n, 1, sint)

for i in range(n):
    decomp[i][0] = M[0][i].bit_decompose()[0]

print_ln('Bit: %s, Op: %s', decomp[0][0].reveal(), M[0][0].reveal())
