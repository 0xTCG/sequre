sfix.set_precision(32, 64)

m = 1
n = 8192

M = Matrix(m, n, sfix)
ones = Matrix(m, n, cfix)

for i in range(m):
    for j in range(n):
        M[i][j] = sfix.get_input_from(0) + 0.1
        ones[i][j] = cfix(1.1)

mul_M = M.schur(ones)
print_ln('Prod: %s, Fact: %s', mul_M[0][1].reveal(), M[0][1].reveal())
